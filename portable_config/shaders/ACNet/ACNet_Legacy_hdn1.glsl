//!DESC [ACNet_Legacy_hdn1] (v3.1) deconv 8x1x2x2
//!WHEN OUTPUT.w LUMA.w / 1.2 > OUTPUT.h LUMA.h / 1.2 > *
//!COMPONENTS 1
//!WIDTH LUMA.w 2 *
//!HEIGHT LUMA.h 2 *
//!HOOK LUMA
//!BIND TMP1_TEX_0
//!BIND TMP1_TEX_1
vec4 hook() {
    vec2 f0 = fract(TMP1_TEX_0_pos * TMP1_TEX_0_size);
    vec2 p0 = TMP1_TEX_0_pos + (vec2(0.5) - f0) * TMP1_TEX_0_pt;
    ivec2 i0 = ivec2(f0 * vec2(2.0));

    vec4 r0 = TMP1_TEX_0_tex(p0);
    vec4 r1 = TMP1_TEX_1_tex(p0);

    float result = 0;

    switch(i0.y * 2 + i0.x)
    {
    case 0:
        result += dot(vec4(0.08823079, -0.32090637, 0.103366494, 0.36212367), r0);
        result += dot(vec4(0.2229542, -0.20973343, 0.2420552, 0.113712706), r1);
        break;
    case 1:
        result += dot(vec4(0.04217615, -0.48703396, 0.017324746, -0.16450234), r0);
        result += dot(vec4(0.30264825, 0.18938252, 0.3362843, -0.21652377), r1);
        break;
    case 2:
        result += dot(vec4(0.37754962, -0.03835839, 0.5011001, -0.13042568), r0);
        result += dot(vec4(0.1618423, -0.032564044, -0.09384978, 0.22727896), r1);
        break;
    case 3:
        result += dot(vec4(0.4754364, 0.053030144, 0.38997793, 0.0012911111), r0);
        result += dot(vec4(-0.45135668, 0.14343265, 0.31557024, -0.12837523), r1);
        break;
    }

    return vec4(clamp(result, 0.0, 1.0), 0.0, 0.0, 1.0);
}
