//!WHEN OUTPUT.w LUMA.w / 1.2 > OUTPUT.h LUMA.h / 1.2 > *
//!COMPONENTS 1
//!WIDTH LUMA.w 2 *
//!HEIGHT LUMA.h 2 *
//!HOOK LUMA
//!BIND TMP1_TEX_0
//!BIND TMP1_TEX_1
vec4 hook() {
    vec2 f0 = fract(TMP1_TEX_0_pos * TMP1_TEX_0_size);
    vec2 p0 = TMP1_TEX_0_pos + (vec2(0.5) - f0) * TMP1_TEX_0_pt;
    ivec2 i0 = ivec2(f0 * vec2(2.0));

    vec4 r0 = TMP1_TEX_0_tex(p0);
    vec4 r1 = TMP1_TEX_1_tex(p0);

    float result = 0;

    switch(i0.y * 2 + i0.x)
    {
    case 0:
        result += dot(vec4(0.49078947, -0.0014691342, -0.29807493, 0.33307847), r0);
        result += dot(vec4(0.23635788, -0.37147278, 0.23777665, -0.08506925), r1);
        break;
    case 1:
        result += dot(vec4(-0.045654465, -0.31522423, 0.09122834, 0.28530642), r0);
        result += dot(vec4(0.07923404, 0.1403556, 0.15704143, 0.27706197), r1);
        break;
    case 2:
        result += dot(vec4(-0.17156102, 0.30449453, 0.012190725, 0.22100307), r0);
        result += dot(vec4(0.28854126, -0.026041213, -0.57340115, 0.041496564), r1);
