//!DESC [ACNet_Legacy_hdn2] (v3.1) deconv 8x1x2x2
//!WHEN OUTPUT.w LUMA.w / 1.2 > OUTPUT.h LUMA.h / 1.2 > *
//!COMPONENTS 1
//!WIDTH LUMA.w 2 *
//!HEIGHT LUMA.h 2 *
//!HOOK LUMA
//!BIND TMP1_TEX_0
//!BIND TMP1_TEX_1
vec4 hook() {
    vec2 f0 = fract(TMP1_TEX_0_pos * TMP1_TEX_0_size);
    vec2 p0 = TMP1_TEX_0_pos + (vec2(0.5) - f0) * TMP1_TEX_0_pt;
    ivec2 i0 = ivec2(f0 * vec2(2.0));

    vec4 r0 = TMP1_TEX_0_tex(p0);
    vec4 r1 = TMP1_TEX_1_tex(p0);

    float result = 0;

    switch(i0.y * 2 + i0.x)
    {
    case 0:
        result += dot(vec4(0.42401108, -0.09849026, -0.1368322, 0.2458229), r0);
        result += dot(vec4(-0.3976746, 0.39020374, 0.04952383, 0.3061316), r1);
        break;
    case 1:
        result += dot(vec4(0.41652867, -0.4454817, 0.4412722, -0.32561386), r0);
        result += dot(vec4(-0.042187653, 0.059423674, 0.13089569, 0.1826789), r1);
        break;
    case 2:
        result += dot(vec4(0.1648087, 0.46388388, 0.25386885, -0.047912773), r0);
        result += dot(vec4(-0.27362013, -0.07206775, -0.17031361, 0.2443201), r1);
        break;
    case 3:
        result += dot(vec4(0.19086978, -0.053325247, 0.32935733, 0.31999472), r0);
        result += dot(vec4(0.10534088, -0.298755, 0.0033250283, -0.1259047), r1);
        break;
    }

    return vec4(clamp(result, 0.0, 1.0), 0.0, 0.0, 1.0);
}
