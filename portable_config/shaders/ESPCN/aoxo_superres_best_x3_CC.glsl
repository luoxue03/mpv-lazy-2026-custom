//!BIND FIN_BLURRED
//!BIND REF_BLURRED
//!BIND REF
//!DESC [aoxo_superres_best_x3_CC] merge
//!WIDTH FIN_UNC.w
//!HEIGHT FIN_UNC.h
//!WHEN OUTPUT.w HOOKED.w 2.200 * > OUTPUT.h HOOKED.h 2.200 * > *

vec4 hook() {
    vec4 sharpened_color = FIN_UNC_texOff(0.0);
    vec4 blurred_sharpened = FIN_BLURRED_texOff(0.0);
    vec4 blurred_ref = REF_BLURRED_texOff(0.0);
