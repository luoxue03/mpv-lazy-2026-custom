//!HOOK MAIN
//!BIND conv6
//!BIND HOOKED
//!DESC [QCOM_quicksrnet_medium_x2] Clip+PixelShuffle x2
//!WIDTH HOOKED.w 2 *
//!HEIGHT HOOKED.h 2 *
//!WHEN OUTPUT.w HOOKED.w 1.200 * > OUTPUT.h HOOKED.h 1.200 * > *
//!COMPUTE 32 32 32 32

void hook() {
    ivec2 opos = ivec2(gl_GlobalInvocationID.xy);
    ivec2 ipos = opos / 2;
    ivec2 sub = opos % 2;
    int sub_idx = sub.y * 2 + sub.x;
    ivec2 base_pixel = ipos * ivec2(3, 1);
    vec4 orig = texelFetch(HOOKED_raw, ipos, 0) * HOOKED_mul;
    vec4 result = vec4(0.0, 0.0, 0.0, orig.a);
    int ch0 = 0 + sub_idx;
    int tile0 = ch0 / 4;
    int comp0 = ch0 % 4;
    ivec2 toff0 = ivec2(tile0 % 3, tile0 / 3);
    vec4 tv0 = conv6_mul * texelFetch(conv6_raw, base_pixel + toff0, 0);
    result.r = tv0[comp0];
    int ch1 = 4 + sub_idx;
    int tile1 = ch1 / 4;
    int comp1 = ch1 % 4;
    ivec2 toff1 = ivec2(tile1 % 3, tile1 / 3);
    vec4 tv1 = conv6_mul * texelFetch(conv6_raw, base_pixel + toff1, 0);
    result.g = tv1[comp1];
    int ch2 = 8 + sub_idx;
    int tile2 = ch2 / 4;
    int comp2 = ch2 % 4;
    ivec2 toff2 = ivec2(tile2 % 3, tile2 / 3);
    vec4 tv2 = conv6_mul * texelFetch(conv6_raw, base_pixel + toff2, 0);
    result.b = tv2[comp2];
    imageStore(out_image, opos, clamp(result, 0.0, 1.0));
}

