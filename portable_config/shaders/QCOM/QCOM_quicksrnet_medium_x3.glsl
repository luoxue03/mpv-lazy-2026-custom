//!HOOK MAIN
//!BIND conv6
//!BIND HOOKED
//!DESC [QCOM_quicksrnet_medium_x3] Clip+PixelShuffle x3
//!WIDTH HOOKED.w 3 *
//!HEIGHT HOOKED.h 3 *
//!WHEN OUTPUT.w HOOKED.w 2.200 * > OUTPUT.h HOOKED.h 2.200 * > *
//!COMPUTE 32 32 32 32

void hook() {
    ivec2 opos = ivec2(gl_GlobalInvocationID.xy);
    ivec2 ipos = opos / 3;
    ivec2 sub = opos % 3;
    int sub_idx = sub.y * 3 + sub.x;
    ivec2 base_pixel = ipos * ivec2(7, 1);
    vec4 orig = texelFetch(HOOKED_raw, ipos, 0) * HOOKED_mul;
    vec4 result = vec4(0.0, 0.0, 0.0, orig.a);
    int ch0 = 0 + sub_idx;
    int tile0 = ch0 / 4;
    int comp0 = ch0 % 4;
    ivec2 toff0 = ivec2(tile0 % 7, tile0 / 7);
    vec4 tv0 = conv6_mul * texelFetch(conv6_raw, base_pixel + toff0, 0);
    result.r = tv0[comp0];
    int ch1 = 9 + sub_idx;
    int tile1 = ch1 / 4;
    int comp1 = ch1 % 4;
    ivec2 toff1 = ivec2(tile1 % 7, tile1 / 7);
    vec4 tv1 = conv6_mul * texelFetch(conv6_raw, base_pixel + toff1, 0);
    result.g = tv1[comp1];
    int ch2 = 18 + sub_idx;
    int tile2 = ch2 / 4;
    int comp2 = ch2 % 4;
    ivec2 toff2 = ivec2(tile2 % 7, tile2 / 7);
    vec4 tv2 = conv6_mul * texelFetch(conv6_raw, base_pixel + toff2, 0);
    result.b = tv2[comp2];
    imageStore(out_image, opos, clamp(result, 0.0, 1.0));
}

