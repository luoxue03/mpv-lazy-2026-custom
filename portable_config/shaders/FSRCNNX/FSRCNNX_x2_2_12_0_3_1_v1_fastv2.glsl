//!HOOK LUMA
//!WHEN OUTPUT.w LUMA.w / 1.200 > OUTPUT.h LUMA.h / 1.200 > *
//!DESC [FSRCNNX_x2_2_12_0_3_1_v1_fastv2] aggregation
//!WIDTH LUMA.w 2 *
//!HEIGHT LUMA.h 2 *
//!COMPUTE 64 64 32 32
//!BIND SUBCONV
void hook()
{
const ivec2 real_pixel = ivec2(gl_GlobalInvocationID);
const ivec2 local_pixel = real_pixel*ivec2(2,2);
const vec2 samplePos = (vec2(real_pixel)+vec2(0.5)) * SUBCONV_pt;
const vec4 value = vec4(SUBCONV_tex(samplePos));
imageStore(out_image, local_pixel+ivec2(0,0), vec4(value.x,0,0,1));
imageStore(out_image, local_pixel+ivec2(0,1), vec4(value.y,0,0,1));
imageStore(out_image, local_pixel+ivec2(1,0), vec4(value.z,0,0,1));
imageStore(out_image, local_pixel+ivec2(1,1), vec4(value.w,0,0,1));
}
